              "raw": "{{baseUrl}}/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Transaction fields present', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.have.property('ledgerTransactionId');",
                  "  pm.expect(body.data).to.have.property('amount');",
                  "  pm.expect(body.data).to.have.property('status');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "WL_A106 — Get Transaction (Not Found)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "00000000-0000-0000-0000-000000000000"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('TRANSACTION_NOT_FOUND message', () => {",
                  "  pm.expect(pm.response.json().message).to.eql('TRANSACTION_NOT_FOUND');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
