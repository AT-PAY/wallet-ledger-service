      ]
    },
    {
      "name": "Journal / Audit",
      "item": [
        {
          "name": "WL_A301 — Get Journal",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}/journal",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}", "journal"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Journal is array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});",
                  "pm.test('Journal entries have required fields', () => {",
                  "  const body = pm.response.json();",
                  "  if (body.data.length > 0) {",
                  "    pm.expect(body.data[0]).to.have.property('action');",
                  "    pm.expect(body.data[0]).to.have.property('performedBy');",
                  "    pm.expect(body.data[0]).to.have.property('timestamp');",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
